# Production site URL (sitemap, OG, email redirects, Paystack callback)
NEXT_PUBLIC_SITE_URL=https://adab.ng

# Supabase Auth redirect URLs (configure in dashboard too):
# - Site URL: https://adab.ng
# - Redirect URLs: https://adab.ng/auth/callback, https://adab.ng/portal/verify-email

# Supabase â€” required for inquiries, admin CMS, and lister portal
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side writes (inquiries, analytics, webhooks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Listing approval emails (Resend) â€” sent to listers when admin publishes a listing
# Without RESEND_API_KEY, approvals still succeed; email content is logged server-side.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Adab Real Estate <hello@adab.ng>

# Paystack (tenant rent payments) â€” optional until online payments are enabled
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
# Webhook URL (Paystack dashboard â†’ Settings â†’ Webhooks):
# https://adab.ng/api/payments/paystack/webhook

# Flutterwave (alternative payments) â€” Phase 2 scaffold (webhook ready; checkout TBD)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_flutterwave_public
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_flutterwave_public
# Secret hash from Flutterwave dashboard â†’ Settings â†’ Webhooks (verif-hash header)
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_hash

# OPay (alternative payments) — scaffold (webhook + cashier init when configured)
OPAY_MERCHANT_ID=your_opay_merchant_id
OPAY_PUBLIC_KEY=your_opay_public_key
OPAY_PRIVATE_KEY=your_opay_private_key
# Webhook URL (OPay merchant dashboard):
# https://adab.ng/api/payments/opay/webhook
