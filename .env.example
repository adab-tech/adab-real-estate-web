# Production site URL (sitemap, OG, email redirects, Paystack callback)
NEXT_PUBLIC_SITE_URL=https://adab.ng

# Supabase Auth redirect URLs (configure in dashboard too):
# - Site URL: https://adab.ng
# - Redirect URLs: https://adab.ng/auth/callback, https://adab.ng/portal/verify-email

# Supabase — required for inquiries, admin CMS, and lister portal
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side writes (inquiries, analytics, webhooks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Listing approval emails (Resend) — sent to listers when admin publishes a listing
# Without RESEND_API_KEY, approvals still succeed; email content is logged server-side.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Adab Real Estate <hello@adab.ng>
ADMIN_ALERT_EMAIL=hello@adab.ng

# Google Generative AI (Gemini) — Phase 1 AI features
# Powers listing descriptions, NL property search, inquiry triage, application summaries
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Cloudflare Turnstile — bot protection on public forms (optional; skipped if unset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Upstash Redis — rate limiting on forms and AI routes (optional; skipped if unset)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Analytics — optional third-party tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id

# Live chat — Tawk.to (preferred) or Crisp fallback
# Tawk format: propertyId/widgetId (from embed URL)
NEXT_PUBLIC_TAWK_PROPERTY_ID=your_property_id/your_widget_id
NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-website-id

# Paystack (tenant rent payments) — optional until online payments are enabled
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
# Webhook URL (Paystack dashboard → Settings → Webhooks):
# https://adab.ng/api/payments/paystack/webhook

# Flutterwave (alternative payments) — Phase 2 scaffold (webhook ready; checkout TBD)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_flutterwave_public
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_flutterwave_public
# Secret hash from Flutterwave dashboard → Settings → Webhooks (verif-hash header)
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_hash

# OPay (alternative payments) — scaffold (webhook + cashier init when configured)
OPAY_MERCHANT_ID=your_opay_merchant_id
OPAY_PUBLIC_KEY=your_opay_public_key
OPAY_PRIVATE_KEY=your_opay_private_key
# Webhook URL (OPay merchant dashboard):
# https://adab.ng/api/payments/opay/webhook
