# Production site URL (sitemap, OG, email redirects)
NEXT_PUBLIC_SITE_URL=https://adab.ng

# Supabase Auth redirect URLs (configure in dashboard too):
# - Site URL: https://adab.ng
# - Redirect URLs: https://adab.ng/auth/callback, https://adab.ng/portal/verify-email

# Supabase — required for inquiries, admin CMS, and lister portal
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: server-side inquiry inserts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Listing approval emails (Resend) — sent to listers when admin publishes a listing
# Without RESEND_API_KEY, approvals still succeed; email content is logged server-side.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Adab Real Estate <hello@adab.ng>
